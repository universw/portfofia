{
  "hosting": {
    "public": "public",  // <--- IMPORTANT: Verify this directory name (e.g., 'dist', 'build', or 'public')
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}